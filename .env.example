# Google Cloud
GOOGLE_CLOUD_PROJECT=your-project-id
VERTEX_AI_LOCATION=us-central1

# Model
MODEL_NAME=gemini-3.1-flash-live-preview

# Database (Cloud SQL PostgreSQL)
DATABASE_URL=postgresql://user:password@/dbname?host=/cloudsql/project:region:instance
# For local dev:
# DATABASE_URL=postgresql://user:password@localhost:5432/uni_guide

# ADK Session table prefix (avoid collisions if sharing DB with other projects)
ADK_SESSION_TABLE_PREFIX=waypoint_

# Server
PORT=8080
HOST=0.0.0.0

# CORS — space-separated list of allowed origins
CORS_ORIGINS=http://localhost:8000 https://your-cloud-run-url.run.app

# Optional: Google API key for local dev without Vertex AI
# GOOGLE_API_KEY=your-key-here
